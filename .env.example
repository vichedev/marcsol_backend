# Aplicación
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=cambiar_aqui
DB_DATABASE=web_dinamica
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_at_least_32_chars_random_secret
JWT_EXPIRES_IN=1d

# Cookies de sesión
# - En desarrollo (HTTP, mismo origen vía proxy de Vite) deja COOKIE_SECURE=false y COOKIE_SAMESITE=lax
# - En producción (HTTPS) usa COOKIE_SECURE=true. Si el frontend está en otro dominio, COOKIE_SAMESITE=none
COOKIE_NAME=ws_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# CORS — separa varios orígenes con coma. Ej: http://localhost:5173,https://admin.midominio.com
CORS_ORIGIN=http://localhost:5173

# Bcrypt (mínimo recomendado: 12)
BCRYPT_SALT_ROUNDS=12

# Rate limiting global (peticiones por ventana en ms)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# Seed del primer admin (solo se usa al iniciar si no existe ningún seed)
# Si tu contraseña contiene `#`, `$` o espacios, ENVUÉLVELA entre comillas dobles
# (dotenv trata `#` como inicio de comentario):
#   SEED_ADMIN_PASSWORD="MiPassConHash#YDolar$"
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=cambiar_al_iniciar_sesion
SEED_ADMIN_NAME=Super Admin

# Uploads
UPLOAD_DEST=./uploads
UPLOAD_MAX_SIZE=5242880
